page {
  background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
  min-height: 100vh;
  padding: 0;
  box-sizing: border-box;
}

.container {
  padding: 0 24rpx 32rpx;
  max-width: 680rpx;
  margin: 0 auto;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0 24rpx;
}

.header-content {
  display: flex;
  align-items: center;
}

.header-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.3;
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.status-indicator {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.1);
}

.status-indicator.connected {
  background: rgba(76, 175, 80, 0.15);
}

.status-indicator.connecting {
  background: rgba(255, 152, 0, 0.15);
}

.status-indicator.failed,
.status-indicator.offline {
  background: rgba(244, 67, 54, 0.15);
}

.indicator-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  background: #999;
}

.status-indicator.connected .indicator-dot {
  background: #4caf50;
}

.status-indicator.connecting .indicator-dot {
  background: #ff9800;
  animation: pulse 1.5s infinite;
}

.status-indicator.failed .indicator-dot,
.status-indicator.offline .indicator-dot {
  background: #f44336;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.indicator-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.status-indicator.connected .indicator-text {
  color: #4caf50;
}

.status-indicator.connecting .indicator-text {
  color: #ff9800;
}

.status-indicator.failed .indicator-text,
.status-indicator.offline .indicator-text {
  color: #f44336;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.update-time {
  margin-left: auto;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.clear-btn {
  margin-left: auto;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  background: transparent;
}

.data-section {
  margin-bottom: 20rpx;
}

.data-grid {
  display: flex;
  gap: 12rpx;
}

.data-card {
  flex: 1;
  background: linear-gradient(145deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.2);
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
}

.data-card.temp {
  background: linear-gradient(145deg, rgba(251, 146, 60, 0.15) 0%, rgba(239, 68, 68, 0.15) 100%);
  border-color: rgba(251, 146, 60, 0.2);
  box-shadow: 0 8rpx 32rpx rgba(251, 146, 60, 0.1);
}

.data-card.humi {
  background: linear-gradient(145deg, rgba(56, 189, 248, 0.15) 0%, rgba(96, 165, 250, 0.15) 100%);
  border-color: rgba(56, 189, 248, 0.2);
  box-shadow: 0 8rpx 32rpx rgba(56, 189, 248, 0.1);
}

.data-card.rain {
  background: linear-gradient(145deg, rgba(14, 165, 233, 0.15) 0%, rgba(6, 182, 212, 0.15) 100%);
  border-color: rgba(14, 165, 233, 0.2);
  box-shadow: 0 8rpx 32rpx rgba(14, 165, 233, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.card-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.card-body {
  display: flex;
  align-items: baseline;
}

.data-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}

.data-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-left: 6rpx;
}

.person-section {
  margin-bottom: 20rpx;
}

.person-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.person-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.person-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.person-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 8rpx;
}

.person-value {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  word-break: break-all;
}

.control-section {
  margin-bottom: 20rpx;
}

.control-list {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 24rpx;
  padding: 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.control-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 8rpx;
  background: rgba(255, 255, 255, 0.03);
}

.control-item:last-child {
  margin-bottom: 0;
}

.control-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.control-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  background: rgba(102, 126, 234, 0.15);
}

.control-icon-wrap.relay {
  background: rgba(102, 126, 234, 0.15);
}

.control-icon-wrap.beep {
  background: rgba(251, 146, 60, 0.15);
}

.control-icon {
  font-size: 36rpx;
}

.control-info {
  display: flex;
  flex-direction: column;
}

.control-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.control-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-top: 6rpx;
}

.control-switch {
  transform: scale(1.2);
}



.action-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s;
}

.action-btn.refresh {
  background: rgba(102, 126, 234, 0.15);
  color: #818cf8;
  border-color: rgba(102, 126, 234, 0.3);
}

.action-btn.refresh:active {
  background: rgba(102, 126, 234, 0.25);
}

.action-btn.auto {
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.7);
  border-color: rgba(255, 255, 255, 0.1);
}

.action-btn.auto.active {
  background: rgba(76, 175, 80, 0.15);
  color: #4ade80;
  border-color: rgba(76, 175, 80, 0.3);
}

.action-btn.auto:active {
  background: rgba(255, 255, 255, 0.1);
}

.action-icon {
  margin-right: 10rpx;
  font-size: 28rpx;
}

.log-section {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.log-list {
  max-height: 200rpx;
}

.log-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
}

.log-item:last-child {
  border-bottom: none;
}

.log-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  width: 120rpx;
  flex-shrink: 0;
}

.log-icon {
  font-size: 24rpx;
  width: 36rpx;
  flex-shrink: 0;
}

.log-item.success .log-icon {
  color: #4ade80;
}

.log-item.error .log-icon {
  color: #f87171;
}

.log-item.info .log-icon {
  color: #60a5fa;
}

.log-message {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  flex: 1;
  margin-left: 12rpx;
}

.empty-log {
  text-align: center;
  padding: 60rpx 20rpx;
  color: rgba(255, 255, 255, 0.2);
  font-size: 26rpx;
}